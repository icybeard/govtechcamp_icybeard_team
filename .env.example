# Скопируйте в .env (cp .env.example .env) и поменяйте значения.
# .env в git не коммитится; читается и docker-compose, и локальным dotnet run.

# Суперпользователь (создаётся/повышается до Admin при старте API)
SEED_ADMIN_EMAIL=admin@icybeard.local
SEED_ADMIN_PASSWORD=ChangeMe123!

# Ключ подписи JWT (минимум 32 символа)
JWT_KEY=dev-only-signing-key-change-in-production-0123456789abcdef

# NASA FIRMS MAP_KEY — очаги пожаров на карте И-9 (бесплатно: firms.modaps.eosdis.nasa.gov/api)
FIRMS_MAP_KEY=